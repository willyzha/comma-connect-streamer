# ==========================================
# REQUIRED: Comma.ai Connectivity
# ==========================================
# Your Comma.ai Dongle ID (found in Comma Connect)
# NOTE: This can be overridden by the COMMA_DONGLE_ID environment variable
COMMA_DONGLE_ID=your_dongle_id_here

# Your Comma.ai JWT Key (found in Comma Connect)
# NOTE: This can be overridden by the COMMA_JWT_KEY environment variable
COMMA_JWT_KEY=your_jwt_key_here


# ==========================================
# OPTIONAL: Stream Behavior
# ==========================================
# Set to False to disable "burn-in" timestamps and metadata
# WRITE_TIMESTAMPS=True

# Set to True to disable the Comma download script entirely
# DISABLE_COMMA=false

# How many days back to look for driving clips
# TIME_RANGE_DAYS=3

# Delay (in minutes) to wait before attempting to download a new clip
# END_TIMEDELTA_MINUTES=5

# Delete clips from disk after they've been streamed
# DELETE_CLIPS=True


# ==========================================
# OPTIONAL: Advanced / Paths
# ==========================================
# Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Check the database before downloading a segment
# CHECK_DATABASE=True

# Stop searching for clips once we hit one that's already processed
# STOP_AT_FIRST_PROCESSED=True

# Number of retries for failed HTTP requests
# HTTP_REQUEST_RETRIES=10

# Path to the SQLite database
# DATABASE_PATH=/config/comma_downloads.db

# Path to the Linux FIFO for streaming
# FIFO_PATH=/dev/shm/new_clip.fifo

# Temporary download directory for clips
# DOWNLOAD_PATH=/dev/shm/dashcam/clips

# Path to the ffmpeg binary
# FFMPEG_PATH=/usr/bin/ffmpeg

# Path to the font file used for overlays
# FONT_PATH=/usr/share/fonts/roboto/Roboto-Thin.ttf

# Font size of the timestamp and route-id overlays
# FONT_SIZE=12

# Path to the "Loading" screen video clip
# LOADING_PATH=/app/loading.ts

# Path to the "Offline" screen video clip
# OFFLINE_PATH=/app/offline.ts
